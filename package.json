{
  "name": "cockpit",
  "version": "0.1.0",
  "description": "All-In-One Cockpit - Terminal, Web Browser, Notes, Project Accounting, GMail/GCal, Slack, WhatsApp, VS Code, TZ, 3D View, Black Box, …",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "@slack/socket-mode": "^2.0.7",
    "@slack/web-api": "^7.17.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "chart.js": "^4.5.1",
    "googleapis": "^173.0.0",
    "node-emoji": "^2.2.0",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "ssh2": "^1.15.0"
  },
  "build": {
    "appId": "com.local.cockpit",
    "productName": "Cockpit",
    "files": [
      "main.js",
      "ssh-manager.js",
      "slack-manager.js",
      "google-manager.js",
      "store.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.png",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    }
  }
}
